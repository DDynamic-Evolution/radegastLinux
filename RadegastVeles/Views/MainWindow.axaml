<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Radegast.Veles.ViewModels"
        xmlns:views="using:Radegast.Veles.Views"
        x:Class="Radegast.Veles.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="{Binding Title}"
        Width="1024" Height="768"
        AutomationProperties.Name="Radegast Veles main window">

    <Window.KeyBindings>
        <!-- Tab Navigation: Ctrl+1 bis Ctrl+8 -->
        <KeyBinding Gesture="Ctrl+1" Command="{Binding ShowTabCommand}" CommandParameter="0" />
        <KeyBinding Gesture="Ctrl+2" Command="{Binding ShowTabCommand}" CommandParameter="1" />
        <KeyBinding Gesture="Ctrl+3" Command="{Binding ShowTabCommand}" CommandParameter="2" />
        <KeyBinding Gesture="Ctrl+4" Command="{Binding ShowTabCommand}" CommandParameter="3" />
        <KeyBinding Gesture="Ctrl+5" Command="{Binding ShowTabCommand}" CommandParameter="4" />
        <KeyBinding Gesture="Ctrl+6" Command="{Binding ShowTabCommand}" CommandParameter="5" />
        <KeyBinding Gesture="Ctrl+7" Command="{Binding ShowTabCommand}" CommandParameter="6" />
        <KeyBinding Gesture="Ctrl+8" Command="{Binding ShowTabCommand}" CommandParameter="7" />
        
        <!-- World Actions -->
        <KeyBinding Gesture="Ctrl+H" Command="{Binding TeleportHomeCommand}" />
        
        <!-- File Actions -->
        <KeyBinding Gesture="Ctrl+," Command="{Binding OpenPreferencesCommand}" />
        <KeyBinding Gesture="Ctrl+Q" Command="{Binding LogoutCommand}" />
        <KeyBinding Gesture="Ctrl+W" Command="{Binding HideWindowCommand}" />
        
        <!-- Help Actions -->
        <KeyBinding Gesture="Ctrl+Shift+L" Command="{Binding OpenLogViewerCommand}" />
    </Window.KeyBindings>

    <DockPanel>
        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top" AutomationProperties.Name="Main menu">
            <MenuItem Header="_File" AutomationProperties.Name="File menu">
                <MenuItem Header="_Preferences" Command="{Binding OpenPreferencesCommand}"
                          InputGesture="Ctrl+," AutomationProperties.Name="Preferences" />
                <Separator />
                <MenuItem Header="_Logout" Command="{Binding LogoutCommand}"
                          InputGesture="Ctrl+Q" AutomationProperties.Name="Logout agent" />
                <MenuItem Header="_Hide Window" Command="{Binding HideWindowCommand}"
                          InputGesture="Ctrl+W" AutomationProperties.Name="Hide window" />
                <Separator />
                <MenuItem Header="E_xit" AutomationProperties.Name="Exit application"
                          Click="OnExitClick" />
            </MenuItem>
            <MenuItem Header="_World" AutomationProperties.Name="World menu">
                <MenuItem Header="Teleport _Home" Command="{Binding TeleportHomeCommand}"
                          InputGesture="Ctrl+H" AutomationProperties.Name="Teleport to home" />
                <Separator />
                <MenuItem Header="_My Profile" AutomationProperties.Name="Open my profile"
                          Click="OnShowMyProfileClick" />
                <MenuItem Header="_Search" AutomationProperties.Name="Open search"
                          Click="OnShowSearchClick" />
                <Separator />
                <MenuItem Header="_Nearby" Command="{Binding ShowTabCommand}" CommandParameter="0"
                          InputGesture="Ctrl+1" AutomationProperties.Name="Show nearby tab" />
                <MenuItem Header="_IMs" Command="{Binding ShowTabCommand}" CommandParameter="1"
                          InputGesture="Ctrl+2" AutomationProperties.Name="Show IMs tab" />
                <MenuItem Header="_Map" Command="{Binding ShowTabCommand}" CommandParameter="2"
                          InputGesture="Ctrl+3" AutomationProperties.Name="Show map tab" />
                <MenuItem Header="_Objects" Command="{Binding ShowTabCommand}" CommandParameter="3"
                          InputGesture="Ctrl+4" AutomationProperties.Name="Show objects tab" />
                <MenuItem Header="_Inventory" Command="{Binding ShowTabCommand}" CommandParameter="4"
                          InputGesture="Ctrl+5" AutomationProperties.Name="Show inventory tab" />
                <MenuItem Header="_Friends" Command="{Binding ShowTabCommand}" CommandParameter="5"
                          InputGesture="Ctrl+6" AutomationProperties.Name="Show friends tab" />
                <MenuItem Header="_Groups" Command="{Binding ShowTabCommand}" CommandParameter="6"
                          InputGesture="Ctrl+7" AutomationProperties.Name="Show groups tab" />
                <MenuItem Header="_Media" Command="{Binding ShowTabCommand}" CommandParameter="7"
                          InputGesture="Ctrl+8" AutomationProperties.Name="Show media tab" />
                <Separator />
                <MenuItem Header="_Mute List" AutomationProperties.Name="Show mute list"
                          Click="OnShowMuteListClick" />
                <Separator />
                <MenuItem Header="_Land Info" AutomationProperties.Name="Show land info"
                          Click="OnShowLandInfoClick" />
                <MenuItem Header="_Land Holdings" AutomationProperties.Name="Show land holdings"
                          Click="OnShowLandHoldingsClick" />
                <MenuItem Header="_Region Info" AutomationProperties.Name="Show region info"
                          Click="OnShowEstateInfoClick" />
            </MenuItem>
            <MenuItem Header="_Create" AutomationProperties.Name="Create menu">
                <MenuItem Header="Upload _Image..." AutomationProperties.Name="Upload image"
                          Click="OnUploadImageClick" />
                <MenuItem Header="Upload _Mesh..." AutomationProperties.Name="Upload mesh"
                          Click="OnUploadMeshClick" />
                <MenuItem Header="Upload _Sound..." AutomationProperties.Name="Upload sound"
                          Click="OnUploadSoundClick" />
                <MenuItem Header="Upload _Animation..." AutomationProperties.Name="Upload animation"
                          Click="OnUploadAnimationClick" />
            </MenuItem>
            <MenuItem Header="_Help" AutomationProperties.Name="Help menu">
                <MenuItem Header="_Log Viewer" Command="{Binding OpenLogViewerCommand}"
                          InputGesture="Ctrl+Shift+L" AutomationProperties.Name="Open log viewer" />
                <Separator />
                <MenuItem Header="_Website" AutomationProperties.Name="Open project website"
                          Click="OnWebsiteClick" />
                <MenuItem Header="_Issue Tracker" AutomationProperties.Name="Open issue tracker"
                          Click="OnIssueTrackerClick" />
                <MenuItem Header="Check for _Updates..." AutomationProperties.Name="Check for updates"
                          Click="OnCheckForUpdatesClick" />
                <Separator />
                <MenuItem Header="_About Radegast Veles" AutomationProperties.Name="About Radegast Veles"
                          Click="OnAboutClick" />
            </MenuItem>
        </Menu>

        <!-- Status bar -->
        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="*,Auto" Margin="4,2" AutomationProperties.Name="Status bar">
            <Grid.Styles>
                <Style Selector="Button.locationLink">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="MinWidth" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                </Style>
                <Style Selector="Button.locationLink:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Background" Value="Transparent" />
                </Style>
                <Style Selector="Button.locationLink TextBlock">
                    <Setter Property="TextDecorations" Value="Underline" />
                </Style>
            </Grid.Styles>

            <TextBlock Grid.Column="0" Text="{Binding StatusText}" VerticalAlignment="Center" AutomationProperties.Name="Status message" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                        AutomationProperties.Name="Current location">
                <TextBlock Text="{Binding BalanceText}" VerticalAlignment="Center" FontWeight="SemiBold"
                           IsVisible="{Binding BalanceText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           AutomationProperties.Name="L$ balance" />
                <TextBlock Text="·" VerticalAlignment="Center" Opacity="0.4"
                           IsVisible="{Binding BalanceText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <Button Classes="locationLink"
                        Command="{Binding Chat.ShowEstateProfileCommand}"
                        IsVisible="{Binding Chat.HasRegionName}"
                        AutomationProperties.Name="{Binding Chat.RegionName, StringFormat=Open region info for {0}}">
                    <TextBlock Text="{Binding Chat.RegionName}" FontWeight="SemiBold" />
                </Button>
                <TextBlock Text="{Binding Chat.LocationCoords}" VerticalAlignment="Center" Opacity="0.7" />
                <TextBlock Text="·" VerticalAlignment="Center" Opacity="0.4" IsVisible="{Binding Chat.HasParcelName}" />
                <Button Classes="locationLink"
                        Command="{Binding Chat.ShowParcelProfileCommand}"
                        IsVisible="{Binding Chat.HasParcelName}"
                        AutomationProperties.Name="{Binding Chat.ParcelName, StringFormat=Open parcel info for {0}}">
                    <TextBlock Text="{Binding Chat.ParcelName}" />
                </Button>
                <Border Background="{Binding Chat.MaturityBrush}" CornerRadius="3" Padding="4,1"
                        IsVisible="{Binding Chat.HasRegionName}" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Chat.MaturityText}" FontSize="10" Foreground="White" />
                </Border>
            </StackPanel>
        </Grid>

        <!-- Tabbed console area with overlaid script-dialog panel -->
        <Grid>
        <TabControl x:Name="MainTabControl" SelectedIndex="{Binding SelectedTabIndex}" AutomationProperties.Name="Console tabs">
            <TabItem AutomationProperties.Name="{Binding Chat.UnreadTabLabel}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="Nearby" VerticalAlignment="Center" />
                        <TextBlock Text="●" Foreground="OrangeRed" FontSize="8"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding Chat.HasUnread}"
                                   AutomationProperties.Name="" />
                    </StackPanel>
                </TabItem.Header>
                <ContentControl Content="{Binding Chat}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:NearbyViewModel">
                            <views:ChatPanel />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </TabItem>
            <TabItem AutomationProperties.Name="{Binding IM.UnreadTabLabel}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="IMs" VerticalAlignment="Center" />
                        <TextBlock Text="●" Foreground="OrangeRed" FontSize="8"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding IM.HasUnreadAny}"
                                   AutomationProperties.Name="" />
                    </StackPanel>
                </TabItem.Header>
                <ContentControl Content="{Binding IM}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:IMViewModel">
                            <views:IMPanel />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </TabItem>
            <TabItem AutomationProperties.Name="World map tab">
                <TabItem.Header>
                    <TextBlock Text="World Map" VerticalAlignment="Center" />
                </TabItem.Header>
                <ContentControl Content="{Binding Map}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:MapViewModel">
                            <views:MapPanel />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </TabItem>
            <TabItem AutomationProperties.Name="Objects tab">
                <TabItem.Header>
                    <TextBlock Text="Objects" VerticalAlignment="Center" />
                </TabItem.Header>
                <ContentControl Content="{Binding Objects}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:ObjectsViewModel">
                            <views:ObjectsPanel />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </TabItem>
            <TabItem AutomationProperties.Name="Inventory tab">
                <TabItem.Header>
                    <TextBlock Text="Inventory" VerticalAlignment="Center" />
                </TabItem.Header>
                <ContentControl Content="{Binding Inventory}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:InventoryViewModel">
                            <views:InventoryPanel />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </TabItem>
            <TabItem AutomationProperties.Name="Friends tab">
                <TabItem.Header>
                    <TextBlock Text="Friends" VerticalAlignment="Center" />
                </TabItem.Header>
                <ContentControl Content="{Binding Friends}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:FriendsViewModel">
                            <views:FriendsPanel />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </TabItem>
            <TabItem AutomationProperties.Name="Groups tab">
                <TabItem.Header>
                    <TextBlock Text="Groups" VerticalAlignment="Center" />
                </TabItem.Header>
                <ContentControl Content="{Binding Groups}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:GroupsViewModel">
                            <views:GroupsPanel />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </TabItem>
            <TabItem AutomationProperties.Name="Media tab">
                <TabItem.Header>
                    <TextBlock Text="Media" VerticalAlignment="Center" />
                </TabItem.Header>
                <ContentControl Content="{Binding Media}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:MediaViewModel">
                            <views:MediaPanel />
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </TabItem>
        </TabControl>

        <!-- Notification overlay: bottom-right of content area -->
        <ContentControl Content="{Binding Notifications}"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,8,8"
            AutomationProperties.Name="Notifications">
            <ContentControl.ContentTemplate>
                <DataTemplate x:DataType="vm:NotificationQueueViewModel">
                    <views:ScriptDialogOverlay />
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>

        </Grid>
    </DockPanel>
</Window>