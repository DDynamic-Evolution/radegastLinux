<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Radegast.Veles.ViewModels"
        xmlns:views="using:Radegast.Veles.Views"
        x:Class="Radegast.Veles.Views.PreferencesWindow"
        x:DataType="vm:PreferencesViewModel"
        Title="Preferences"
        Width="540" Height="500"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        AutomationProperties.Name="Preferences window">
    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="8,4,8,8" Spacing="6">
            <Button Content="OK" Click="OnOkClick" IsDefault="True" AutomationProperties.Name="OK" />
            <Button Content="Apply" Click="OnApplyClick" AutomationProperties.Name="Apply" />
            <Button Content="Cancel" Click="OnCancelClick" IsCancel="True" AutomationProperties.Name="Cancel" />
        </StackPanel>
        <TabControl Margin="8,8,8,4" AutomationProperties.Name="Preferences tabs">
            <TabItem Header="General" AutomationProperties.Name="General preferences">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8" Spacing="12">
                        <TextBlock Text="Image Cache" FontWeight="SemiBold" FontSize="14" />
                        <CheckBox Content="Enable image cache" IsChecked="{Binding ImageCacheEnabled}" AutomationProperties.Name="Enable image cache" />
                        <Grid ColumnDefinitions="160,*,40" IsEnabled="{Binding ImageCacheEnabled}">
                            <TextBlock Grid.Column="0" Text="Cache expiry (minutes)" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" Minimum="1" Maximum="1440" Value="{Binding ImageCacheExpireMinutes}" AutomationProperties.Name="Cache expiry in minutes" />
                            <TextBlock Grid.Column="2" Text="{Binding ImageCacheExpireMinutes}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid ColumnDefinitions="160,*,40">
                            <TextBlock Grid.Column="0" Text="Decode concurrency" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" Minimum="1" Maximum="{Binding MaxDecodeConcurrency}" Value="{Binding ImageDecodeConcurrency}" AutomationProperties.Name="Image decode concurrency" />
                            <TextBlock Grid.Column="2" Text="{Binding ImageDecodeConcurrency}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>
                        <Separator />
                        <TextBlock Text="Display Names" FontWeight="SemiBold" FontSize="14" />
                        <TextBlock Text="How avatar names are shown in chat and other lists." FontSize="11" Opacity="0.65" TextWrapping="Wrap" />
                        <ListBox ItemsSource="{Binding DisplayNameModeOptions}"
                                 SelectedIndex="{Binding DisplayNameMode}"
                                 HorizontalAlignment="Stretch"
                                 Height="120"
                                 AutomationProperties.Name="Display name mode">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding }" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Separator />
                        <TextBlock Text="Paths" FontWeight="SemiBold" FontSize="14" />
                        <TextBlock Text="Chat Logging" FontWeight="SemiBold" />
                        <CheckBox Content="Enable chat logging" IsChecked="{Binding ChatLoggingEnabled}"
                                  AutomationProperties.Name="Enable chat logging" />
                        <TextBlock Text="Chat Log Directory" Opacity="0.7" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0" Text="{Binding ChatLogDir}"
                                     Watermark="Default (%APPDATA%\RadegastVeles)"
                                     IsEnabled="{Binding ChatLoggingEnabled}"
                                     AutomationProperties.Name="Chat log directory path" />
                            <Button Grid.Column="1" Content="Browse&#x2026;" Margin="4,0,0,0"
                                    Click="OnBrowseChatLogDirClick"
                                    IsEnabled="{Binding ChatLoggingEnabled}"
                                    AutomationProperties.Name="Browse for chat log directory" />
                        </Grid>
                        <TextBlock Text="Image Cache Directory" Opacity="0.7" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0" Text="{Binding ImageCacheDir}"
                                     AutomationProperties.Name="Image cache directory path" />
                            <Button Grid.Column="1" Content="Browse&#x2026;" Margin="4,0,0,0"
                                    Click="OnBrowseImageCacheDirClick"
                                    AutomationProperties.Name="Browse for image cache directory" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Audio" AutomationProperties.Name="Audio preferences">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8" Spacing="12">
                        <TextBlock Text="Volumes" FontWeight="SemiBold" FontSize="14" />
                        <Grid ColumnDefinitions="120,*,40">
                            <TextBlock Grid.Column="0" Text="Master Volume" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding MasterVolume}" IsEnabled="{Binding SoundSystemAvailable}" AutomationProperties.Name="Master volume slider" />
                            <TextBlock Grid.Column="2" Text="{Binding MasterVolume, StringFormat='{}{0}%'}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid ColumnDefinitions="120,*,40">
                            <TextBlock Grid.Column="0" Text="Stream Volume" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding StreamVolume}" IsEnabled="{Binding SoundSystemAvailable}" AutomationProperties.Name="Stream volume slider" />
                            <TextBlock Grid.Column="2" Text="{Binding StreamVolume, StringFormat='{}{0}%'}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid ColumnDefinitions="120,*,40">
                            <TextBlock Grid.Column="0" Text="Object Volume" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding ObjectVolume}" IsEnabled="{Binding SoundSystemAvailable}" AutomationProperties.Name="Object volume slider" />
                            <TextBlock Grid.Column="2" Text="{Binding ObjectVolume, StringFormat='{}{0}%'}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid ColumnDefinitions="120,*,40">
                            <TextBlock Grid.Column="0" Text="UI Volume" VerticalAlignment="Center" />
                            <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding UiVolume}" IsEnabled="{Binding SoundSystemAvailable}" AutomationProperties.Name="UI volume slider" />
                            <TextBlock Grid.Column="2" Text="{Binding UiVolume, StringFormat='{}{0}%'}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>
                        <Separator />
                        <TextBlock Text="Behavior" FontWeight="SemiBold" FontSize="14" />
                        <CheckBox Content="Auto-play parcel audio" IsChecked="{Binding AutoPlay}" AutomationProperties.Name="Auto-play parcel audio" />
                        <CheckBox Content="Keep URL on parcel change" IsChecked="{Binding KeepUrl}" AutomationProperties.Name="Keep URL on parcel change" />
                        <CheckBox Content="Enable object sounds" IsChecked="{Binding ObjectSoundsEnabled}" AutomationProperties.Name="Enable object sounds" />
                        <Separator />
                        <TextBlock Text="Audio Device" FontWeight="SemiBold" FontSize="14" />
                        <ComboBox ItemsSource="{Binding AudioDevices}" SelectedItem="{Binding SelectedAudioDevice}" IsEnabled="{Binding SoundSystemAvailable}" HorizontalAlignment="Stretch" AutomationProperties.Name="Audio device selection" />
                        <Separator />
                        <TextBlock Text="Audio Profiles" FontWeight="SemiBold" FontSize="14" />
                        <Grid ColumnDefinitions="*,Auto">
                            <ComboBox Grid.Column="0" ItemsSource="{Binding AudioProfiles}" SelectedItem="{Binding SelectedProfile}" HorizontalAlignment="Stretch" AutomationProperties.Name="Audio profile selection" />
                            <Button Grid.Column="1" Content="Load" Margin="4,0,0,0" Command="{Binding LoadProfileCommand}" AutomationProperties.Name="Load audio profile" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
                    <TabItem Header="Grids" AutomationProperties.Name="Grid preferences">
                        <Grid RowDefinitions="*,Auto" Margin="8">
                            <Grid Grid.Row="0" ColumnDefinitions="180,*">
                                <!-- Left: grid list + Add/Remove -->
                                <DockPanel Grid.Column="0" Margin="0,0,8,0">
                                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                                Spacing="4" Margin="0,6,0,0">
                                        <Button Content="Add" Command="{Binding AddNewGridCommand}"
                                                AutomationProperties.Name="Add grid" />
                                        <Button Content="Remove" Command="{Binding RemoveGridCommand}"
                                                AutomationProperties.Name="Remove grid" />
                                    </StackPanel>
                                    <ListBox ItemsSource="{Binding Grids}"
                                             SelectedItem="{Binding SelectedGrid}"
                                             AutomationProperties.Name="Grid list">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                                <!-- Right: edit form -->
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock Text="Select a grid or click Add."
                                               Opacity="0.55" FontStyle="Italic"
                                               IsVisible="{Binding !IsFormActive}" />
                                    <StackPanel Spacing="6" IsVisible="{Binding IsFormActive}">
                                        <TextBlock Text="Grid ID" Opacity="0.7" />
                                        <TextBox Text="{Binding EditGridId}"
                                                 IsReadOnly="{Binding !IsEditingNewGrid}"
                                                 Watermark="auto-generated if blank"
                                                 AutomationProperties.Name="Grid ID" />
                                        <TextBlock Text="Name" Opacity="0.7" />
                                        <TextBox Text="{Binding EditGridName}"
                                                 AutomationProperties.Name="Grid name" />
                                        <TextBlock Text="Login URI" Opacity="0.7" />
                                        <TextBox Text="{Binding EditGridLoginUri}"
                                                 AutomationProperties.Name="Grid login URI" />
                                        <Button Content="Save" Command="{Binding SaveGridCommand}"
                                                HorizontalAlignment="Right"
                                                AutomationProperties.Name="Save grid" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <TextBlock Grid.Row="1"
                                       Text="Built-in grids (agni, aditi) cannot be removed."
                                       FontSize="11" Opacity="0.65" Margin="0,6,0,0" />
                        </Grid>
                    </TabItem>
                    <TabItem Header="RLV" AutomationProperties.Name="RLV preferences">
                        <views:RlvPanel DataContext="{Binding Rlv}" />
                    </TabItem>
                    <TabItem Header="MQTT" AutomationProperties.Name="MQTT preferences">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8" Spacing="12">
                                <TextBlock Text="MQTT"
                                           FontWeight="SemiBold" FontSize="14" />
                                <TextBlock Text="Connect to an MQTT broker to publish chat/IM events and receive commands."
                                           TextWrapping="Wrap" FontSize="11" Opacity="0.65" />

                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                      VerticalAlignment="Top" Grid.ColumnSpan="2">
                                    <TextBlock Text="Host:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,4" />
                                    <TextBox Text="{Binding Mqtt.Host}" Grid.Row="0" Grid.Column="1" Margin="0,0,0,4"
                                             AutomationProperties.Name="MQTT host" />
                                    <TextBlock Text="Port:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,4" />
                                    <TextBox Text="{Binding Mqtt.Port}" Grid.Row="1" Grid.Column="1" Margin="0,0,0,4"
                                             AutomationProperties.Name="MQTT port" />
                                    <TextBlock Text="Username:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,4" />
                                    <TextBox Text="{Binding Mqtt.Username}" Grid.Row="2" Grid.Column="1" Margin="0,0,0,4"
                                             AutomationProperties.Name="MQTT username" />
                                    <TextBlock Text="Password:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,4" />
                                    <TextBox Text="{Binding Mqtt.Password}" Grid.Row="3" Grid.Column="1" Margin="0,0,0,4"
                                             AutomationProperties.Name="MQTT password" />
                                    <TextBlock Text="Root Topic:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,4" />
                                    <TextBox Text="{Binding Mqtt.RootTopic}" Grid.Row="4" Grid.Column="1" Margin="0,0,0,4"
                                             AutomationProperties.Name="MQTT root topic" />
                                    <TextBlock Text="QoS:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,4" />
                                    <ComboBox SelectedIndex="{Binding Mqtt.Qos}" Grid.Row="5" Grid.Column="1" Margin="0,0,0,4"
                                              AutomationProperties.Name="MQTT QoS">
                                        <ComboBox.Items>0 1 2</ComboBox.Items>
                                    </ComboBox>
                                <CheckBox Content="Use TLS" IsChecked="{Binding Mqtt.UseTls}"
                                          Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,4"
                                          AutomationProperties.Name="Use TLS" />
                                <CheckBox Content="Auto-connect on startup" IsChecked="{Binding Mqtt.AutoConnect}"
                                          Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,4"
                                          AutomationProperties.Name="Auto-connect on startup" />
                            </Grid>

                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                    <Button Content="Save" Command="{Binding Mqtt.SaveCommand}"
                                            AutomationProperties.Name="Save MQTT settings" />
                                    <Button Content="Disconnect"
                                            Command="{Binding Mqtt.ToggleConnectionCommand}"
                                            IsVisible="{Binding Mqtt.IsConnected}"
                                            AutomationProperties.Name="Disconnect MQTT" />
                                    <Button Content="Connect"
                                            Command="{Binding Mqtt.ToggleConnectionCommand}"
                                            IsVisible="{Binding Mqtt.IsConnected, Converter={x:Static BoolConverters.Not}}"
                                            AutomationProperties.Name="Connect MQTT" />
                                </StackPanel>

                                <TextBlock Text="Connected" FontSize="11" Opacity="0.65"
                                           IsVisible="{Binding Mqtt.IsConnected}" />
                                <TextBlock Text="Disconnected" FontSize="11" Opacity="0.65"
                                           IsVisible="{Binding Mqtt.IsConnected, Converter={x:Static BoolConverters.Not}}" />

                                <Separator />
                                <TextBlock Text="Publish Options" FontWeight="SemiBold" FontSize="12" />
                                <CheckBox Content="Publish outgoing chat" IsChecked="{Binding Mqtt.PublishChatSend}" />
                                <CheckBox Content="Publish incoming chat" IsChecked="{Binding Mqtt.PublishChatReceive}" />
                                <CheckBox Content="Publish outgoing IMs" IsChecked="{Binding Mqtt.PublishImSend}" />
                                <CheckBox Content="Publish incoming IMs" IsChecked="{Binding Mqtt.PublishImReceive}" />
                                <CheckBox Content="Publish location" IsChecked="{Binding Mqtt.PublishLocation}" />
                                <CheckBox Content="Subscribe to commands" IsChecked="{Binding Mqtt.SubscribeCommands}" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="VPN" AutomationProperties.Name="VPN preferences">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8" Spacing="12">
                                <TextBlock Text="WireGuard VPN"
                                           FontWeight="SemiBold" FontSize="14" />
                                <TextBlock Text="Manage WireGuard tunnel profiles. Requires the vpn-helper binary with CAP_NET_ADMIN (set via sudo setcap cap_net_admin+ep vpn-helper)."
                                           TextWrapping="Wrap" FontSize="11" Opacity="0.65" />

                                <ListBox ItemsSource="{Binding Vpn.Profiles}"
                                         SelectedItem="{Binding Vpn.SelectedProfile}"
                                         Height="120"
                                         AutomationProperties.Name="VPN profiles">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button Content="Add" Command="{Binding Vpn.AddProfileCommand}" />
                                    <Button Content="Edit" Command="{Binding Vpn.EditProfileCommand}"
                                            IsEnabled="{Binding Vpn.SelectedProfile, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                    <Button Content="Remove" Command="{Binding Vpn.RemoveProfileCommand}"
                                            IsEnabled="{Binding Vpn.SelectedProfile, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                    <Button Content="Connect" Command="{Binding Vpn.ConnectProfileCommand}"
                                            IsEnabled="{Binding Vpn.SelectedProfile, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                    <Button Content="Disconnect" Command="{Binding Vpn.DisconnectProfileCommand}"
                                            IsEnabled="{Binding Vpn.IsConnected}" />
                                </StackPanel>

                                <TextBlock Text="{Binding Vpn.StatusText}" FontSize="11" Opacity="0.7" />

                                <StackPanel Spacing="6" IsVisible="{Binding Vpn.IsEditing}">
                                    <Separator />
                                    <TextBlock Text="Profile" FontWeight="SemiBold" />
                                    <Grid ColumnDefinitions="100,*">
                                        <TextBlock Grid.Column="0" Text="Name" />
                                        <TextBox Grid.Column="1" Text="{Binding Vpn.EditName}" />
                                    </Grid>
                                    <Grid ColumnDefinitions="100,*">
                                        <TextBlock Grid.Column="0" Text="Private Key" />
                                        <TextBox Grid.Column="1" Text="{Binding Vpn.EditPrivateKey}" />
                                    </Grid>
                                    <Grid ColumnDefinitions="100,*">
                                        <TextBlock Grid.Column="0" Text="Address" />
                                        <TextBox Grid.Column="1" Text="{Binding Vpn.EditAddress}" Watermark="10.0.0.2/24" />
                                    </Grid>
                                    <Separator />
                                    <TextBlock Text="Peer" FontWeight="SemiBold" />
                                    <Grid ColumnDefinitions="100,*">
                                        <TextBlock Grid.Column="0" Text="Public Key" />
                                        <TextBox Grid.Column="1" Text="{Binding Vpn.EditPeerPublicKey}" />
                                    </Grid>
                                    <Grid ColumnDefinitions="100,*">
                                        <TextBlock Grid.Column="0" Text="Endpoint" />
                                        <TextBox Grid.Column="1" Text="{Binding Vpn.EditPeerEndpoint}" Watermark="1.2.3.4:51820" />
                                    </Grid>
                                    <Grid ColumnDefinitions="100,*">
                                        <TextBlock Grid.Column="0" Text="Allowed IPs" />
                                        <TextBox Grid.Column="1" Text="{Binding Vpn.EditPeerAllowedIPs}" Watermark="0.0.0.0/0" />
                                    </Grid>
                                    <Grid ColumnDefinitions="100,*,80">
                                        <TextBlock Grid.Column="0" Text="Keepalive (s)" />
                                        <TextBox Grid.Column="1" Text="{Binding Vpn.EditPeerKeepalive}" />
                                        <TextBlock Grid.Column="2" Text="0 = off" FontSize="11" Opacity="0.6" VerticalAlignment="Center" Margin="4,0,0,0" />
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                        <Button Content="Save" Command="{Binding Vpn.SaveProfileCommand}" />
                                        <Button Content="Cancel" Command="{Binding Vpn.CancelEditCommand}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </Window>